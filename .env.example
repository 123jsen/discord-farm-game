# Discord Application Client ID
# Found at: Discord Developer Portal > Your App > OAuth2 > Client ID
CLIENT_ID=

# Discord Server (Guild) ID
# Found at: Discord > Right-click your server > Copy Server ID (requires Developer Mode)
# Leave empty to register commands globally (takes up to 1 hour to propagate)
GUILD_ID=

# Discord Bot Token
# Found at: Discord Developer Portal > Your App > Bot > Token (click "Reset Token" if hidden)
# Keep this secret — anyone with this token can control your bot
CLIENT_TOKEN=

# MongoDB Connection String
# Found at: MongoDB Atlas > Your Cluster > Connect > Drivers > Copy connection string
# Replace <password> with your database user's password
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/discord-farm-game
